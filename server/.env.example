# --- PULSE server config ---

PORT=4000
CORS_ORIGIN=http://localhost:5173

# Feed source:
#   sim    — fabricated matches (no creds; lively but moments are unverified)
#   replay — REAL past fixture scripted with its real goals/cards; every moment
#            auto-verifies on Solana. Needs a TxLINE token. ← best demo.
#   live   — real TxLINE SSE (real-time; empty on devnet, fixtures only scheduled)
FEED_MODE=sim

# Reaction aggregation window in ms (architecture: ~250)
AGG_WINDOW_MS=250

# --- On-chain network (picks program id, API base, TxL mint, Solana RPC) ---
# "devnet" (free, no real SOL) or "mainnet"
NETWORK=devnet

# --- TxLINE live feed (only needed for FEED_MODE=live) ---
# Filled in automatically by: npm run setup:txline -w @pulse/server
TXLINE_JWT=
TXLINE_API_TOKEN=
# Service level auto-picks by NETWORK (devnet=1 / 60s delay, mainnet=12 / real-time).
# Only set this to override; devnet ONLY supports level 1.
# TXLINE_SERVICE_LEVEL=
TXLINE_DURATION_WEEKS=4

# --- Solana subscribe (only needed to RUN setup:txline) ---
# Path to a Solana CLI keypair JSON (array of bytes):
#   solana-keygen new --outfile ~/pulse-devnet.json
#   solana config set --url devnet && solana airdrop 2
TXLINE_WALLET_KEYPAIR=~/pulse-devnet.json
# Overrides (defaults follow NETWORK; usually leave blank):
# SOLANA_RPC=
# TXLINE_PROGRAM_ID=
# TXLINE_TXL_MINT=
# TXLINE_BASE_URL=
