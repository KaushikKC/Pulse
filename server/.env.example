# --- PULSE server config ---

PORT=4000
CORS_ORIGIN=http://localhost:5173

# "sim" (default, no creds needed) or "live" (real TxLINE SSE)
FEED_MODE=sim

# Reaction aggregation window in ms (architecture: ~250)
AGG_WINDOW_MS=250

# --- TxLINE (only needed for FEED_MODE=live) ---
TXLINE_BASE_URL=https://txline.txodds.com
# Guest JWT from POST /auth/guest/start
TXLINE_JWT=
# API token from POST /api/token/activate (after Solana subscribe to Service Level 12)
TXLINE_API_TOKEN=
TXLINE_SERVICE_LEVEL=12
